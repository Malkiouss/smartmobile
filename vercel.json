{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install --prefix car/client && npm install --prefix car/server",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    },
    {
      "src": "server/routes/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server/routes/cars.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/server/routes/auth.js"
    }
  ]
}
